# Runtime mode
APP_ENV=development
TRADING_MODE=dry_run
ALLOW_LIVE_TRADING=false

# Schedule / calendar
MARKET_CALENDAR=NASDAQ
REBALANCE_AFTER_OPEN_MINUTES=10

# Strategy
UNIVERSE=us_top_market_cap
RANK_LOOKBACK_DAYS=90
MAX_HOLDINGS=50
STRATEGY_ALLOCATIONS=rank_velocity_size_equal_weight=0.98,cash=0.02
# DRY_RUN_PORTFOLIO_VALUE_USD is only used in dry_run mode. Paper/live size against broker
# equity; see MANAGED_CAP_MODE.
DRY_RUN_PORTFOLIO_VALUE_USD=10000
MANAGED_CAP_MODE=broker_total
MANAGED_CAP_USD=0
MAX_POSITION_PCT=0.10
MAX_TURNOVER_PCT=1.0
MIN_TRADE_NOTIONAL_USD=25
MIN_WEIGHT_DELTA_PCT=0.0025

# Execution safety
ORDER_TYPE=limit
ALLOW_MARKET_ORDERS=false
LIMIT_OFFSET_BPS=10
MAX_ORDER_NOTIONAL_USD=2000
MAX_DAILY_TRADES=100
# IBKR rejects fractional-sized API orders (error 10243), so orders are sized in whole shares:
# buys round to the nearest whole share, sells round down. Only set true for accounts confirmed
# to accept fractional API orders.
FRACTIONAL_SHARES=false

# Execution pricing: paper/live orders reprice off a fresh IBKR quote captured immediately
# before submission (and again on reconciliation replace), not the Yahoo screener snapshot used
# for universe/target planning. BUY references the ask, SELL references the bid, by default.
EXECUTION_PRICE_SOURCE=ibkr
EXECUTION_PRICE_BASIS=side_of_market
EXECUTION_QUOTE_MAX_AGE_SECONDS=60
EXECUTION_MAX_SPREAD_BPS=50
# Defaults by trading mode when unset: true for dry_run/paper (accounts commonly lack the
# separate IBKR "API market data" real-time opt-in even when delayed data is available), false
# for live. Deploy validation hard-fails TRADING_MODE=live with this set to true; live trading
# needs the real-time API market data subscription instead (see docs/production-readiness.md).
ALLOW_DELAYED_EXECUTION_QUOTES=true
# When true, `poma ibkr-check` hard-fails unless the probe receives a real-time-class tick
# (live, or frozen when the market is closed); delayed-only or silent probes never soft-pass.
REQUIRE_LIVE_EXECUTION_QUOTES=false
# Per-step wait for the readiness probe's market data type ladder; delayed steps wait 2x.
MARKET_DATA_PROBE_WAIT_SECONDS=5
ALLOW_LAST_PRICE_FALLBACK=false
ALLOW_UNSAFE_EXECUTION_PRICE_SOURCE=false
ORDER_STATUS_TIMEOUT_SECONDS=60
CANCEL_STALE_ORDERS=true
# Order lifecycle management (post-acceptance): DAY orders never carry over to the next
# session; a still-working limit order is replaced once after REPLACE_AFTER_SECONDS with a
# more aggressive price, then cancelled after CANCEL_AFTER_SECONDS if still unfilled. Run
# `poma reconcile-orders` on a schedule to apply this policy after the rebalance process exits.
ORDER_TIME_IN_FORCE=DAY
REPLACE_AFTER_SECONDS=120
CANCEL_AFTER_SECONDS=300
REPLACE_PRICE_IMPROVEMENT_BPS=15
STALE_ORDER_POLICY=block

# Data provider
# yahoo is the only production market-data provider. fixture is available for tests/PR dry-runs.
DATA_PROVIDER=yahoo
YAHOO_SCREENER_LIMIT=500
YAHOO_SCREENER_PAGE_SIZE=250

# IBKR Gateway on the same VPS
# CI renders IBKR_ACCOUNT from IBKR_ACCOUNT_PAPER for paper mode and IBKR_ACCOUNT for live mode.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=101
IBKR_ACCOUNT=replace_me

# Local state/reporting
STATE_DIR=state
DATA_DIR=data
REPORT_DIR=reports

# Mandatory Telegram alerts
# TELEGRAM_BOT_TOKEN authenticates the bot; TELEGRAM_CHAT_ID tells Telegram where to send alerts.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
