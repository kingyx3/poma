# Runtime mode
APP_ENV=development
TRADING_MODE=dry_run
ALLOW_LIVE_TRADING=false

# Schedule / calendar
MARKET_CALENDAR=NASDAQ
REBALANCE_AFTER_OPEN_MINUTES=10

# Strategy
UNIVERSE=nasdaq100
RANK_LOOKBACK_PERIODS=21
PORTFOLIO_VALUE_USD=10000
CASH_BUFFER_PCT=0.02
MAX_POSITION_PCT=0.10
MAX_TURNOVER_PCT=0.35
MIN_TRADE_NOTIONAL_USD=25
MIN_WEIGHT_DELTA_PCT=0.01

# Data provider
# Use fixture for local dry-run. Use fmp after validating your subscription endpoints.
DATA_PROVIDER=fixture
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable

# IBKR Gateway on the same VPS
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=101
IBKR_ACCOUNT=

# Local state/reporting
STATE_DIR=state
REPORT_DIR=reports

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
