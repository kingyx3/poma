# Runtime mode
APP_ENV=development
TRADING_MODE=dry_run
ALLOW_LIVE_TRADING=false

# Strategy
UNIVERSE=nasdaq100
REBALANCE_FREQUENCY=monthly
RANK_LOOKBACK_PERIODS=21
PORTFOLIO_VALUE_USD=10000
CASH_BUFFER_PCT=0.02
MAX_POSITION_PCT=0.10
MAX_TURNOVER_PCT=0.35
MIN_TRADE_NOTIONAL_USD=25

# Data provider
DATA_PROVIDER=fixture
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable

# Remote executor on VPS near IB Gateway
EXECUTOR_ENDPOINT=
EXECUTOR_API_KEY=

# IBKR gateway settings used by the executor host
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=101
IBKR_ACCOUNT=

# Local state/reporting
STATE_DIR=var
REPORT_DIR=reports
