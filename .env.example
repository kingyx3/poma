# Runtime mode
APP_ENV=development
TRADING_MODE=dry_run
ALLOW_LIVE_TRADING=false

# Schedule / calendar
MARKET_CALENDAR=NASDAQ
REBALANCE_AFTER_OPEN_MINUTES=10

# Strategy
UNIVERSE=sp500
RANK_LOOKBACK_DAYS=90
MAX_HOLDINGS=100
PORTFOLIO_VALUE_USD=10000
CASH_BUFFER_PCT=0.02
MAX_POSITION_PCT=0.10
MAX_TURNOVER_PCT=0.35
MIN_TRADE_NOTIONAL_USD=25
MIN_WEIGHT_DELTA_PCT=0.0025

# Execution safety
ORDER_TYPE=limit
ALLOW_MARKET_ORDERS=false
LIMIT_OFFSET_BPS=10
MAX_ORDER_NOTIONAL_USD=2000
MAX_DAILY_TRADES=100
ORDER_STATUS_TIMEOUT_SECONDS=60
CANCEL_STALE_ORDERS=true

# Data provider
# Mandatory for production deploys. Use fixture locally only with explicit dummy values.
DATA_PROVIDER=fixture
FMP_API_KEY=replace_me
FMP_BASE_URL=https://financialmodelingprep.com/stable

# IBKR Gateway on the same VPS
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=101
IBKR_ACCOUNT=replace_me

# Local state/reporting
STATE_DIR=state
REPORT_DIR=reports

# Mandatory Telegram alerts
# TELEGRAM_BOT_TOKEN authenticates the bot; TELEGRAM_CHAT_ID tells Telegram where to send alerts.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
