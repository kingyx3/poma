# Check every 5 minutes. POMA decides whether the US market has been open for 10+ minutes
# and whether today's rebalance already ran. This avoids DST-specific cron schedules.
*/5 * * * * cd /opt/poma && bash ops/cron/run_logged.sh /opt/poma/logs/poma-cron.log /usr/bin/docker compose --env-file .compose.env -f docker-compose.vm.yml run --rm poma monitor

# Follow up on working orders independent of the rebalance process lifetime: replaces a
# still-unfilled limit order once after REPLACE_AFTER_SECONDS, cancels it after
# CANCEL_AFTER_SECONDS, and alerts on every lifecycle change. No-op when nothing is open.
*/2 * * * * cd /opt/poma && bash ops/cron/run_logged.sh /opt/poma/logs/poma-reconcile-cron.log /usr/bin/docker compose --env-file .compose.env -f docker-compose.vm.yml run --rm poma reconcile-orders
